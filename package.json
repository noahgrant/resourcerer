{
  "name": "resourcerer",
  "version": "2.2.1",
  "repository": {
    "type": "git",
    "url": "github.com/noahgrant/resourcerer"
  },
  "description": "Declarative data-fetching and caching framework for React",
  "keywords": [
    "declarative data-fetching framework",
    "react"
  ],
  "files": [
    "build/**/*.js",
    "*.d.ts",
    "build/**/*.d.ts",
    "test/*.js",
    "*.md",
    "docs/*.md"
  ],
  "main": "build/index.js",
  "types": "resourcerer.d.ts",
  "type": "module",
  "scripts": {
    "checks": "npm run typecheck && npm test && npm run lint",
    "lint": "eslint lib/*.ts* test/*.js*",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepublish": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --pool threads --poolOptions.threads.singleThread run"
  },
  "exports": {
    ".": {
      "types": "./resourcerer.d.ts",
      "import": "./build/index.js"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/eslint__js": "^8.42.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "react": "^16.14.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.14.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  }
}
